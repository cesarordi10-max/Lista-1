#include <iostream>
using namespace std;

int main() {
    int numero;

    cout << "Introduce un número entre 1 y 20: ";
    cin >> numero;

    // Verificación del rango
    if (numero >= 1 && numero <= 20) {
        switch (numero) {
            case 1: cout << "I"; break;
            case 2: cout << "II"; break;
            case 3: cout << "III"; break;
            case 4: cout << "IV"; break;
            case 5: cout << "V"; break;
            case 6: cout << "VI"; break;
            case 7: cout << "VII"; break;
            case 8: cout << "VIII"; break;
            case 9: cout << "IX"; break;
            case 10: cout << "X"; break;
            case 11: cout << "XI"; break;
            case 12: cout << "XII"; break;
            case 13: cout << "XIII"; break;
            case 14: cout << "XIV"; break;
            case 15: cout << "XV"; break;
            case 16: cout << "XVI"; break;
            case 17: cout << "XVII"; break;
            case 18: cout << "XVIII"; break;
            case 19: cout << "XIX"; break;
            case 20: cout << "XX"; break;
            default: cout << "Número inválido."; break;
        }
    } else {
        cout << "Número fuera del rango (1-20).";
    }

    return 0;
}
